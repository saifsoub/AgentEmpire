# Server runtime configuration
PORT=3000
NODE_ENV=production

# Database and storage configuration
DATABASE_URL=postgres://username:password@host:port/database
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication and session
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret

# External services
BLUECONIC_API_KEY=your-blueconic-api-key
FIGMA_API_TOKEN=your-figma-api-token

# Third-party integrations
STRIPE_SECRET_KEY=your-stripe-secret-key
MAILGUN_API_KEY=your-mailgun-api-key
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Application metadata
APP_NAME=AgentEmpire
APP_URL=https://agent-empire.vercel.app

# Financial Sentiment Trading Monitor
# NewsAPI (https://newsapi.org) — free tier: 100 req/day
NEWS_API_KEY=your-newsapi-key

# Twitter / X API v2 Bearer Token (https://developer.twitter.com)
# Optional — Reddit + GDELT + Yahoo Finance work without it
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Alpha Vantage (https://alphavantage.co) — optional, Yahoo Finance fallback used if missing
ALPHA_VANTAGE_KEY=your-alpha-vantage-key

# Symbols to track (comma-separated). Defaults to SPY,QQQ,VIX
WATCH_SYMBOLS=SPY,QQQ,VIX,AAPL,TSLA

# Anthropic API key for Claude-powered sentiment analysis
# Falls back to keyword heuristics if not set
ANTHROPIC_API_KEY=your-anthropic-api-key

# Copy this file to .env and replace the placeholder values with your actual secrets before running the application.
