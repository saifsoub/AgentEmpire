# Server runtime configuration
PORT=7483
NODE_ENV=development

# Application metadata
APP_NAME=AgentEmpire
APP_URL=http://localhost:7483

# Database and storage configuration
DATABASE_URL=postgres://username:password@host:port/database
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Authentication and session
JWT_SECRET=replace-with-at-least-32-random-bytes
SESSION_SECRET=replace-with-at-least-32-random-bytes

# Agent reasoning providers
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Tool routing and integration providers
TOOL_ROUTER_DEFAULT_PROVIDER=native
TOOL_ROUTER_ENABLED_PROVIDERS=native,manual
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_USER_ID=seif
WEBHOOK_ROUTER_URL=https://your-router.example.com/agent/execute
WEBHOOK_ROUTER_TOKEN=your-webhook-router-token
MCP_SERVER_URL=https://your-mcp-server.example.com
MCP_AUTH_TOKEN=your-mcp-auth-token

# External services
BLUECONIC_API_KEY=your-blueconic-api-key
FIGMA_API_TOKEN=your-figma-api-token

# Third-party integrations
STRIPE_SECRET_KEY=your-stripe-secret-key
MAILGUN_API_KEY=your-mailgun-api-key
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Copy this file to .env.local for local development.
# Keep real secrets out of git and paste only placeholders here.
